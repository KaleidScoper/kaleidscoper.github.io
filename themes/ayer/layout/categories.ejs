<section class="outer">
  <% if (site.categories.length){ %>
    <h1 class="page-type-title"><%= __('categories') %></h1>
    <div class="categories-box">
      <%- category_tree() %>
    </div>
  <% } %>
</section>

<script>
(function () {
  var box = document.querySelector('.categories-box');
  if (!box) return;

  box.addEventListener('click', function (e) {
    var btn = e.target.closest('.cat-toggle');
    if (!btn) return;

    var node = btn.closest('.cat-node');
    if (!node) return;

    var isExpanded = node.getAttribute('data-expanded') === 'true';
    node.setAttribute('data-expanded', String(!isExpanded));
  });
})();
</script>
