// Reward / donation modal
// Follows the same CSS custom-property pattern as share.styl.
// Active state uses elevation (raised card on a recessed track), not color.

// ─── Light mode ───────────────────────────────────────────────────────────────
\:root
  --reward-bg               rgba(252, 250, 247, 0.97)
  --reward-border           rgba(0, 0, 0, 0.07)
  --reward-shadow           0 6px 24px rgba(0, 0, 0, 0.09)
  --reward-text             #333333
  --reward-subtext          #777777
  --reward-overlay          rgba(0, 0, 0, 0.45)

  --reward-tabs-track       rgba(0, 0, 0, 0.06)
  --reward-tab-text         #666666
  --reward-tab-hover        rgba(0, 0, 0, 0.05)
  --reward-tab-active-bg    #ffffff
  --reward-tab-active-text  #333333
  --reward-tab-active-shadow 0 1px 4px rgba(0, 0, 0, 0.13)

  --reward-qr-border        rgba(0, 0, 0, 0.09)

  --reward-btn-bg           rgba(255, 255, 255, 0.55)
  --reward-btn-border       rgba(0, 0, 0, 0.11)
  --reward-btn-text         #555555
  --reward-btn-icon         #888888
  --reward-btn-shadow       0 2px 10px rgba(0, 0, 0, 0.07)
  --reward-btn-hover-bg     rgba(255, 255, 255, 0.80)

// ─── Dark mode ────────────────────────────────────────────────────────────────
body.darkmode
  --reward-bg               rgba(42, 47, 58, 0.97)
  --reward-border           rgba(255, 255, 255, 0.09)
  --reward-shadow           0 6px 24px rgba(0, 0, 0, 0.45)
  --reward-text             #d0d0d0
  --reward-subtext          #aaaaaa
  --reward-overlay          rgba(0, 0, 0, 0.65)

  --reward-tabs-track       rgba(0, 0, 0, 0.28)
  --reward-tab-text         #999999
  --reward-tab-hover        rgba(255, 255, 255, 0.06)
  --reward-tab-active-bg    rgba(255, 255, 255, 0.13)
  --reward-tab-active-text  #d0d0d0
  --reward-tab-active-shadow 0 1px 4px rgba(0, 0, 0, 0.45)

  --reward-qr-border        rgba(255, 255, 255, 0.12)

  --reward-btn-bg           rgba(255, 255, 255, 0.08)
  --reward-btn-border       rgba(255, 255, 255, 0.13)
  --reward-btn-text         #cccccc
  --reward-btn-icon         #999999
  --reward-btn-shadow       0 2px 10px rgba(0, 0, 0, 0.28)
  --reward-btn-hover-bg     rgba(255, 255, 255, 0.14)

// ─── Overlay ──────────────────────────────────────────────────────────────────
#mask
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  z-index 9998
  background var(--reward-overlay)
  display none

// ─── Modal panel ──────────────────────────────────────────────────────────────
.reward-modal
  position fixed
  z-index 9999
  left 50%
  top 50%
  transform translate(-50%, -50%) scale(0.96)
  width 380px
  max-width 92vw
  max-height 88vh
  overflow-y auto
  padding 24px 24px 28px
  background var(--reward-bg)
  -webkit-backdrop-filter blur(16px)
  backdrop-filter blur(16px)
  border 1px solid var(--reward-border)
  border-radius 12px
  box-shadow var(--reward-shadow)
  display none
  opacity 0
  transition opacity 0.25s ease, transform 0.25s ease

  &.visible
    display block
    opacity 1
    transform translate(-50%, -50%) scale(1)

// ─── Close button ─────────────────────────────────────────────────────────────
.reward-close
  position absolute
  right 10px
  top 10px
  width 30px
  height 30px
  display flex
  align-items center
  justify-content center
  border-radius 50%
  cursor pointer
  transition background 0.2s ease
  color var(--reward-subtext)

  &:hover
    background var(--reward-tab-hover)

  i
    font-size 18px
    color var(--reward-subtext)

// ─── Heading ──────────────────────────────────────────────────────────────────
.reward-wording
  text-align center
  font-size 14px
  color var(--reward-subtext)
  margin 4px 0 20px
  line-height 1.5

  i
    margin-right 5px
    color var(--reward-subtext)

// ─── Channel tabs — segmented control ─────────────────────────────────────────
// The track is a recessed container; the active item floats up with a white
// background and shadow. No color is used to communicate selection.
.reward-tabs
  display flex
  gap 3px
  justify-content center
  margin-bottom 20px
  flex-wrap wrap
  background var(--reward-tabs-track)
  border-radius 8px
  padding 3px

.reward-tab
  display inline-flex
  align-items center
  gap 5px
  padding 6px 14px
  border none
  border-radius 6px
  background transparent
  color var(--reward-tab-text)
  font-size 13px
  cursor pointer
  transition background 0.2s ease, color 0.15s ease, box-shadow 0.2s ease
  white-space nowrap
  font-family inherit
  line-height 1.4

  &:hover:not(.active)
    background var(--reward-tab-hover)

  &.active
    background var(--reward-tab-active-bg)
    color var(--reward-tab-active-text)
    font-weight 500
    box-shadow var(--reward-tab-active-shadow)

  i
    font-size 15px
    color inherit

// ─── QR panel ─────────────────────────────────────────────────────────────────
.reward-panel
  display none
  text-align center
  animation rewardFadeIn 0.2s ease

  &.active
    display block

@keyframes rewardFadeIn
  from
    opacity 0
    transform translateY(6px)
  to
    opacity 1
    transform translateY(0)

// Minimal white frame ensures QR codes are scannable in dark mode.
// Exempted from the global darkmode image brightness dimming.
.reward-qrcode-wrap
  display inline-block
  line-height 0
  padding 6px
  border 1px solid var(--reward-qr-border)
  border-radius 8px
  background #ffffff

  body.darkmode &
    filter none

.reward-qrcode
  display block
  width 180px
  height 180px

.reward-desc
  margin 10px 0 0
  font-size 13px
  color var(--reward-subtext)

// Link to payment platform — elevated to match active tab style
.reward-link
  display inline-flex
  align-items center
  gap 4px
  margin-top 12px
  padding 7px 18px
  background var(--reward-tab-active-bg)
  color var(--reward-tab-active-text)
  box-shadow var(--reward-tab-active-shadow)
  border 1px solid var(--reward-border)
  border-radius 6px
  font-size 13px
  font-weight 500
  text-decoration none
  transition opacity 0.2s ease

  &:hover
    opacity 0.8
    text-decoration none
    color var(--reward-tab-active-text)

// ─── Trigger button ───────────────────────────────────────────────────────────
#reward-out
  position relative
  width 100%
  text-align center

.reward-trigger,
#reward-btn
  display inline-flex
  align-items center
  gap 6px
  height 38px
  padding 0 22px
  margin 40px 0
  font-size 14px
  color var(--reward-btn-text)
  background var(--reward-btn-bg)
  -webkit-backdrop-filter blur(10px)
  backdrop-filter blur(10px)
  border 1px solid var(--reward-btn-border)
  border-radius 19px
  cursor pointer
  box-shadow var(--reward-btn-shadow)
  transition all 0.25s ease
  font-family inherit
  line-height 1

  i
    color var(--reward-btn-icon)

  &:hover
    background var(--reward-btn-hover-bg)
    transform translateY(-1px)
    box-shadow 0 4px 16px rgba(0, 0, 0, 0.09)

// ─── Sub-tabs (multi-chain) — same elevation pattern, smaller scale ───────────
.reward-chain-hint
  text-align center
  font-size 13px
  color var(--reward-subtext)
  margin 0 0 10px

.reward-sub-tabs
  display inline-flex
  gap 2px
  justify-content center
  margin-bottom 14px
  background var(--reward-tabs-track)
  border-radius 6px
  padding 2px

.reward-sub-tab
  display inline-flex
  align-items center
  gap 4px
  padding 4px 12px
  border none
  border-radius 4px
  background transparent
  color var(--reward-tab-text)
  font-size 12px
  cursor pointer
  transition background 0.2s ease, color 0.15s ease, box-shadow 0.2s ease
  font-family inherit
  line-height 1.4

  &:hover:not(.active)
    background var(--reward-tab-hover)

  &.active
    background var(--reward-tab-active-bg)
    color var(--reward-tab-active-text)
    font-weight 500
    box-shadow var(--reward-tab-active-shadow)

.reward-sub-badge
  font-size 10px
  padding 1px 5px
  border-radius 4px
  background rgba(0, 0, 0, 0.08)
  color var(--reward-tab-text)
  line-height 1.3

  body.darkmode &
    background rgba(255, 255, 255, 0.12)

.reward-sub-tab.active .reward-sub-badge
  background rgba(0, 0, 0, 0.08)

.reward-sub-panel
  display none
  text-align center
  animation rewardFadeIn 0.2s ease

  &.active
    display block

// ─── Mobile ───────────────────────────────────────────────────────────────────
@media (max-width: 768px)
  .reward-modal
    width 88vw
    padding 20px 18px 24px

  .reward-qrcode
    width 160px
    height 160px

@media (max-width: 480px)
  .reward-tabs,
  .reward-sub-tabs
    flex-wrap nowrap
    overflow-x auto
    justify-content flex-start
    padding-bottom 4px
    -webkit-overflow-scrolling touch

  .reward-qrcode
    width 140px
    height 140px

  .reward-sub-tab
    padding 4px 10px
    font-size 12px
