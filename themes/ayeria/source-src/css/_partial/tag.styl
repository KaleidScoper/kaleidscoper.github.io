// ==========================================================================
// Tags — Minimal Blockquote-Style Grid
//
// Each tag is a block with a short left border (like a blockquote accent),
// tag name above, post count below. Laid out in an equal-width CSS Grid.
//
// All decorative elements use `currentColor` so they follow body text
// color in both light and dark modes automatically.
// ==========================================================================

.tag-cloud
  max-width: 100%
  margin: 2rem 0
  padding: 0

// ---------------------------------------------------------------------------
// Header — Stats + Controls
// ---------------------------------------------------------------------------

.tag-cloud-header
  display: flex
  flex-wrap: wrap
  align-items: center
  justify-content: space-between
  gap: 1rem
  margin-bottom: 2.5rem

.tag-cloud-stats
  font-size: 1.3rem
  opacity: 0.5
  strong
    opacity: 1

.tag-cloud-controls
  display: flex
  align-items: center
  gap: 0.75rem
  flex-wrap: wrap

// ---------------------------------------------------------------------------
// Search Input — underline style, no box
// ---------------------------------------------------------------------------

.tag-cloud-search
  display: flex
  align-items: center

.tag-cloud-input
  width: 160px
  height: 36px
  padding: 0 0.2rem
  border: none
  border-bottom: 1px solid currentColor
  border-radius: 0
  background: transparent
  color: inherit
  font-size: 1.2rem
  outline: none
  opacity: 0.35
  transition: opacity 0.2s
  &:focus
    opacity: 1
  &::placeholder
    color: currentColor
    opacity: 0.5

// ---------------------------------------------------------------------------
// Sort Buttons — text-only, underline active state
// ---------------------------------------------------------------------------

.tag-cloud-sort
  display: flex
  gap: 0.3rem

.tag-sort-btn
  display: inline-flex
  align-items: center
  height: 36px
  padding: 0 0.7rem
  border: none
  border-bottom: 1px solid transparent
  background: none
  color: inherit
  font-size: 1.2rem
  cursor: pointer
  opacity: 0.35
  transition: opacity 0.2s
  &:hover
    opacity: 0.65
  &.is-active
    opacity: 1
    font-weight: 600
    border-bottom-color: currentColor

// ---------------------------------------------------------------------------
// Tag Grid
// ---------------------------------------------------------------------------

.tag-cloud-wrap
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr))
  gap: 2rem

// ---------------------------------------------------------------------------
// Tag Item — left border accent
// ---------------------------------------------------------------------------

.tag-cloud-item
  display: block
  padding: 0.5em 0 0.5em 1em
  border-left: 2px solid currentColor
  text-decoration: none
  color: inherit
  opacity: 0.7
  transition: opacity 0.2s
  &:hover
    opacity: 1

.tag-cloud-name
  display: block
  font-size: 1.8rem
  line-height: 1.5

.tag-cloud-count
  display: block
  font-size: 1.2rem
  opacity: 0.45
  line-height: 1.5

// ---------------------------------------------------------------------------
// Empty State
// ---------------------------------------------------------------------------

.tag-cloud-empty
  display: none
  text-align: center
  padding: 3rem 1rem
  margin: 0
  opacity: 0.5
  font-size: 1rem

// ---------------------------------------------------------------------------
// Responsive
// ---------------------------------------------------------------------------

@media (max-width: 768px)
  .tag-cloud-header
    flex-direction: column
    align-items: flex-start

  .tag-cloud-wrap
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr))
    gap: 1.2rem
